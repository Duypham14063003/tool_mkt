FLASK_ENV=development
SECRET_KEY=replace-with-a-long-random-value
MYSQL_DATABASE=social_dashboard
MYSQL_USER=social_dashboard
MYSQL_PASSWORD=social_dashboard_dev_password
MYSQL_ROOT_PASSWORD=social_dashboard_root_password
MYSQL_PORT=3307
DATABASE_URL=mysql+pymysql://social_dashboard:social_dashboard_dev_password@127.0.0.1:3307/social_dashboard?charset=utf8mb4
TOKEN_ENCRYPTION_KEY=replace-with-a-fernet-key
SESSION_COOKIE_SECURE=false

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:5000/auth/facebook/callback

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:5000/auth/tiktok/callback

